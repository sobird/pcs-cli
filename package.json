{
  "name": "pcs-cli",
  "description": "Baidu Personal Cloud Storage's Command Line Interface.",
  "version": "1.6.0",
  "type": "module",
  "bin": {
    "pcs": "bin/dev.ts"
  },
  "scripts": {
    "dev": "tsx bin/dev.ts",
    "build": "tsup",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsx scripts/prepublish.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sobird/pcs-cli.git"
  },
  "keywords": [
    "pcs-cli",
    "pcs",
    "baidu",
    "baidu-pcs"
  ],
  "bugs": {
    "url": "https://github.com/sobird/pcs-cli/issues"
  },
  "author": {
    "name": "sobird"
  },
  "license": "MIT",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/sobird/pcs-cli/blob/master/LICENSE"
    }
  ],
  "readmeFilename": "README.md",
  "homepage": "https://github.com/sobird/pcs-cli",
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "axios": "^1.13.2",
    "bytes": "^3.1.2",
    "chalk": "^5.6.2",
    "cliui": "^9.0.1",
    "commander": "^14.0.3",
    "dayjs": "^1.11.19",
    "glob": "^13.0.6",
    "open": "^11.0.0",
    "progress": "^2.0.3",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/bytes": "^3.1.4",
    "@types/node": "^20.9.0",
    "@types/progress": "^2.0.7",
    "@types/prompts": "^2.4.8",
    "eslint-config-sobird": "^0.2.16",
    "husky": "^9.0.11",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
